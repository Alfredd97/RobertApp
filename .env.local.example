# AI Provider Configuration
# Available providers: anthropic, gemini
# To add a new provider (e.g., openai), see lib/ai/providers/_template.ts
# Get API keys:
#   - Anthropic: https://console.anthropic.com/account/keys
#   - Google Gemini: https://aistudio.google.com/app/apikey
AI_PROVIDER=anthropic

# API Keys for different providers (only set the one for your chosen provider)
ANTHROPIC_API_KEY=your_anthropic_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_key_here

# Optional: override the default model
# For Anthropic: claude-sonnet-4-6 (default), claude-opus-4-8, claude-haiku-4-5
# For Gemini: gemini-1.5-flash (default), gemini-1.5-pro
# AI_MODEL=claude-sonnet-4-6

# Calendly Integration (optional)
CALENDLY_API_KEY=your_calendly_api_key_here
CALENDLY_API_SECRET_KEY=your_calendly_secret_key_here
CALENDLY_WEBHOOK_URL=your_webhook_url_here
